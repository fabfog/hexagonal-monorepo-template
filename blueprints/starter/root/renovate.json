{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "description": "pnpm workspace baseline for Renovate.",
  "dependencyDashboard": true,
  "dependencyDashboardTitle": "Dependency dashboard",
  "labels": ["dependencies"],
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "rangeStrategy": "auto",
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 6am on the first day of the month"]
  },
  "packageRules": [
    {
      "description": "Group Vitest packages into one PR",
      "matchPackageNames": ["vitest", "@vitest/coverage-v8"],
      "groupName": "vitest"
    },
    {
      "description": "Group @types/* to reduce PR noise",
      "matchPackageNames": ["/^@types\\//"],
      "groupName": "types"
    }
  ]
}
