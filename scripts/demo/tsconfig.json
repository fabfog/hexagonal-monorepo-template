{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../configs/config-typescript/base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "noEmit": true
  },
  "include": ["./**/*.ts"]
}
