{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "generators": {
    "@repo/nx-plugin": {
      "hello": {
        "message": "hexagonal-monorepo-template"
      }
    }
  },
  "plugins": [
    {
      "plugin": "@nx/vitest",
      "options": {
        "testTargetName": "test",
        "ciTargetName": "test-ci",
        "testMode": "watch"
      }
    },
    {
      "plugin": "@nx/eslint/plugin",
      "options": {
        "targetName": "eslint:lint"
      }
    }
  ],
  "analytics": true
}
